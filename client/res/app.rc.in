#include <winres.h>

// Application icon
1 ICON "@ICON_PATH@"

// Version information
VS_VERSION_INFO VERSIONINFO
    FILEVERSION    @RC_VERSION_MAJOR@, @RC_VERSION_MINOR@, @RC_VERSION_PATCH@, @RC_VERSION_BUILD@
    PRODUCTVERSION @RC_VERSION_MAJOR@, @RC_VERSION_MINOR@, @RC_VERSION_PATCH@, @RC_VERSION_BUILD@
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
    FILEFLAGS      VS_FF_DEBUG
#else
    FILEFLAGS      0
#endif
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Open Source"
            VALUE "FileDescription",  "Parties"
            VALUE "FileVersion",      "@RC_VERSION_STR@"
            VALUE "InternalName",     "parties_client"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "parties_client.exe"
            VALUE "ProductName",      "Parties"
            VALUE "ProductVersion",   "@RC_VERSION_STR@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END

// Application manifest (DPI awareness, common controls v6, UTF-8)
CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "app.manifest"
