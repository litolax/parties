{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (clang-cl Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vendor/ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vendor/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-win-llvm",
        "VCPKG_MANIFEST_FEATURES": "client",
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/vendor/ninja/ninja.exe"
      }
    },
    {
      "name": "release",
      "displayName": "Release (clang-cl)",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "asan",
      "displayName": "RelWithDebInfo + ASAN",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build-asan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "macos-arm64-debug",
      "displayName": "macOS ARM64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vendor/ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vendor/triplets",
        "VCPKG_TARGET_TRIPLET": "arm64-osx-debug",
        "VCPKG_MANIFEST_FEATURES": "client-macos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.3",
        "ENABLE_TRACY": "OFF",
        "CMAKE_MAKE_PROGRAM": "/opt/homebrew/bin/ninja"
      }
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS ARM64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vendor/ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vendor/triplets",
        "VCPKG_TARGET_TRIPLET": "arm64-osx-release",
        "VCPKG_MANIFEST_FEATURES": "client-macos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.3",
        "ENABLE_TRACY": "OFF",
        "CMAKE_MAKE_PROGRAM": "/opt/homebrew/bin/ninja"
      }
    },
    {
      "name": "retail",
      "displayName": "Retail (clang-cl Release, no debugger/console)",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build-retail",
      "cacheVariables": {
        "BUILD_IN_RETAIL": "ON"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release (server only)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vendor/ports",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/vendor/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-linux-static",
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/vendor/ninja/ninja-linux",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_C_COMPILER": "gcc",
        "BUILD_CLIENT": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "macos-arm64-debug",
      "configurePreset": "macos-arm64-debug"
    },
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-release"
    },
    {
      "name": "retail",
      "configurePreset": "retail"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    }
  ]
}
