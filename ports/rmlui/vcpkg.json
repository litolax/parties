{
  "name": "rmlui",
  "version": "6.3.0",
  "description": "RmlUi with DX12 support (wh1t3lord fork)",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    "freetype"
  ],
  "features": {
    "freetype": {
      "description": "Include font engine based on FreeType",
      "dependencies": [
        {
          "name": "freetype",
          "default-features": false
        }
      ]
    },
    "svg": {
      "description": "Enable plugin for SVG images",
      "dependencies": [
        "lunasvg"
      ]
    }
  }
}
