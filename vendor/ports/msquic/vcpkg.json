{
  "name": "msquic",
  "version": "2.5.6",
  "port-version": 108,
  "description": "Cross-platform, C implementation of the IETF QUIC protocol (static build, wolfSSL TLS backend)",
  "homepage": "https://github.com/microsoft/msquic",
  "license": "MIT",
  "supports": "(windows & !uwp) | linux | osx",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "wolfssl",
      "features": ["quic"]
    }
  ]
}
